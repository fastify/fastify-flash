{
  "compilerOptions": {
    "moduleResolution": "node16",
    "declaration": true,
    "target": "es2022",
    "module": "node16",
    "outDir": "lib",
    "pretty": true,
    "noEmitOnError": true,
    "sourceMap": false,
    "strictNullChecks": true,
    "strictPropertyInitialization": true,
    "esModuleInterop": true,
    "removeComments": true,
    "noUnusedLocals": true
  },
  "exclude": ["node_modules"],
  "include": ["./src/**/*.ts", "./tests/**/*.ts"],
  "incremental": true
}
